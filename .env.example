# Copy this file to .env and fill in your values.

# Database
DATABASE_URL=postgresql+asyncpg://cognifetch:cognifetch@postgres:5432/cognifetch
SYNC_DATABASE_URL=postgresql+psycopg://cognifetch:cognifetch@postgres:5432/cognifetch

# Object storage (MinIO for local dev; swap endpoint/credentials for S3 in prod)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=cognifetch-docs
S3_REGION=us-east-1

# LLM / embeddings
API_KEY=your-openai-compatible-api-key
OPENAI_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# JWT — generate a strong random secret, e.g.: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
LOG_LEVEL=INFO
