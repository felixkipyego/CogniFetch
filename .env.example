# Copy this file to .env and fill in your values.
#
# Two passwords must be consistent across multiple variables:
#   YOUR_DB_PASSWORD   → POSTGRES_PASSWORD, DATABASE_URL, SYNC_DATABASE_URL (all three must match)
#   YOUR_MINIO_PASSWORD → MINIO_ROOT_PASSWORD, S3_SECRET_ACCESS_KEY (both must match)
#
# Similarly, MINIO_ROOT_USER and S3_ACCESS_KEY_ID must be the same value.

# Database
# Generate a password: openssl rand -hex 16
POSTGRES_USER=cognifetch
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_DB=cognifetch
DATABASE_URL=postgresql+asyncpg://cognifetch:YOUR_DB_PASSWORD@postgres:5432/cognifetch
SYNC_DATABASE_URL=postgresql+psycopg://cognifetch:YOUR_DB_PASSWORD@postgres:5432/cognifetch

# Object storage (MinIO for local dev; swap endpoint/credentials for S3 in prod)
# Generate a password: openssl rand -hex 16
# MINIO_ROOT_USER must equal S3_ACCESS_KEY_ID; MINIO_ROOT_PASSWORD must equal S3_SECRET_ACCESS_KEY
S3_ENDPOINT_URL=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=YOUR_MINIO_PASSWORD
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=YOUR_MINIO_PASSWORD
S3_BUCKET_NAME=cognifetch-docs
S3_REGION=us-east-1

# LLM / embeddings — any OpenAI-compatible provider
API_KEY=your-api-key
OPENAI_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# JWT — generate a strong random secret: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — JSON list of allowed origins
# Local dev:   CORS_ORIGINS=["http://localhost:5173"]
# Production:  CORS_ORIGINS=["https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:5173"]

# App
# Set to "production" on the server
APP_ENV=development
LOG_LEVEL=INFO
