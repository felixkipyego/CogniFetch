# Base URL of the CogniFetch FastAPI backend.
#
# Local dev (Docker Compose running locally):
#   VITE_API_BASE_URL=http://localhost:8000
#
# Production (your server's domain or IP, proxied through Nginx):
#   VITE_API_BASE_URL=https://api.yourdomain.com
#
# Note: this value is baked into the frontend bundle at build time (Vite replaces
# it at compile step). If you change it, run `npm run build` again.
VITE_API_BASE_URL=http://localhost:8000
